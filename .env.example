# ==============================================================================
# ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to `.env` or `.env.local` to configure your environment variables.
# Example: 
#   cp .env.example .env.local

# ── TELEGRAM API TOKEN ──────────────────────────────────────────────
# Obtain this token by talking to BotFather on Telegram.
# 1. Open Telegram and search for @BotFather (or visit https://t.me/BotFather)
# 2. Send the command `/newbot`
# 3. Follow the steps to name your bot.
# 4. Copy the HTTP API token provided by BotFather.
TELEGRAM_BOT_TOKEN=

# ── APP API KEY ─────────────────────────────────────────────────────
# This is a secret key to authenticate your application.
# You can generate a secure random string using your terminal:
#   openssl rand -hex 32
# Or generate one securely online: https://generate-secret.vercel.app/32
API_KEY=
