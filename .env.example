# ==============================================================================
# ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to `.env` or `.env.local` and fill in the values.
# Example:
#   cp .env.example .env.local

# ── CROO SDK KEY ────────────────────────────────────────────────────
# Your CROO Agent SDK key (croo_sk_...) from the CROO Dashboard.
# Required in LIVE mode. Omit only when running with CROO_MOCK=true.
CROO_SDK_KEY=

# ── SUMMON SERVICE ID ───────────────────────────────────────────────
# The registered service ID for your "Human Sign-off" service.
# Register the service in the CROO Dashboard, then paste its ID here.
SUMMON_SERVICE_ID=

# ── TELEGRAM BOT TOKEN ──────────────────────────────────────────────
# Obtain this token by talking to @BotFather on Telegram.
# 1. Open Telegram and message @BotFather (https://t.me/BotFather)
# 2. Send the command `/newbot` and follow the prompts.
# 3. Copy the HTTP API token BotFather gives you.
TELEGRAM_BOT_TOKEN=

# ── TELEGRAM CHAT ID ────────────────────────────────────────────────
# The chat the Approve/Reject prompt is sent to. For a 1:1 DM with your
# bot this is your own user ID (e.g. from @userinfobot).
TELEGRAM_CHAT_ID=

# ── TELEGRAM ALLOWED USER IDS (optional) ────────────────────────────
# Comma-separated Telegram *user* IDs permitted to approve/reject.
# Defaults to TELEGRAM_CHAT_ID (correct for a 1:1 DM). Set this explicitly
# when the prompt is sent to a group chat.
# TELEGRAM_ALLOWED_USER_IDS=

# ── MOCK MODE (optional) ────────────────────────────────────────────
# Set to true for offline development — no USDC spent, no WebSocket opened.
# CROO_MOCK=true
